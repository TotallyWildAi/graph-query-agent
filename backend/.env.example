# Orchestration agent — backend configuration.
# Copy to `.env` for local runs OUTSIDE docker; inside docker compose these are
# supplied by infra/docker-compose.yml. In production, resolve secrets from a
# secrets manager (spec §13) — never commit real credentials.

APP_NAME=orchestration-agent
LOG_LEVEL=INFO

# Neo4j — the knowledge graph.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=orchestrator

# Postgres — the append-only trace & lineage store.
POSTGRES_DSN=postgresql://orchestrator:orchestrator@localhost:5432/trace
